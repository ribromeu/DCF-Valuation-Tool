# DCF Valuation Tool - Environment Variables
# Copy this file to .env and fill in your values
# Never commit your actual .env file to version control

# --- Financial Data API ---
# API key for fetching financial data (e.g., Alpha Vantage, Financial Modeling Prep)
FINANCIAL_API_KEY=your_api_key_here
FINANCIAL_API_BASE_URL=https://financialmodelingprep.com/api/v3

# --- Output Settings ---
# Directory where Excel reports will be saved
OUTPUT_DIR=./outputs

# --- Default Valuation Assumptions ---
# Default discount rate / WACC (%)
DEFAULT_WACC=0.10

# Default terminal growth rate (%)
DEFAULT_TERMINAL_GROWTH_RATE=0.025

# Default projection years
DEFAULT_PROJECTION_YEARS=5

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=dcf_tool.log
